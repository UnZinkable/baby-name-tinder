@model List<string>
@{
    ViewData["Title"] = "Swipe Names";
    var lastName         = ViewBag.LastName as string ?? "";
    var isLinked         = (bool)(ViewBag.IsLinked ?? false);
    var totalCount       = (int)(ViewBag.TotalCount ?? 0);
    var votedCount       = (int)(ViewBag.VotedCount ?? 0);
    var ranks            = ViewBag.Ranks as Dictionary<string, int> ?? new();
    var meaningsJson     = ViewBag.MeaningsJson as string ?? "{}";
    var meanings         = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(meaningsJson) ?? new();
    var remaining        = Model.Count;
}

<div class="swipe-page">
    <div class="container py-3">

        @if (!isLinked)
        {
            <div class="alert alert-info text-center rounded-4 mb-3 py-2">
                <i class="bi bi-info-circle"></i>
                Partner hasn't joined yet. Share your invite code from the
                <a asp-controller="Partner" asp-action="Dashboard" class="fw-semibold">Partner Dashboard</a>.
                Your likes will be saved!
            </div>
        }

        <!-- Progress bar -->
        <div class="mb-3">
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span id="progressLabel">@votedCount of @totalCount names reviewed</span>
                <span id="remainingLabel">@remaining remaining</span>
            </div>
            <div class="progress" style="height: 6px; border-radius: 10px;">
                <div class="progress-bar" id="progressBar"
                     style="width: @(totalCount > 0 ? (votedCount * 100 / totalCount) : 0)%"></div>
            </div>
        </div>

        <!-- Card Stack -->
        <div class="card-stack-container" id="cardContainer">
            @if (remaining == 0)
            {
                <div class="empty-state text-center py-5">
                    <div style="font-size: 4rem;">🎉</div>
                    <h3 class="fw-bold mt-3">You've seen them all!</h3>
                    <p class="text-muted">Check your matches to see what you and your partner both love.</p>
                    <a asp-controller="Match" asp-action="Index" class="btn btn-primary btn-lg mt-2">
                        <i class="bi bi-heart-fill"></i> View Matches
                    </a>
                </div>
            }
            else
            {
                @* Render top 3 cards (only top is interactive) *@
                @for (int i = Math.Min(2, remaining - 1); i >= 0; i--)
                {
                    var name     = Model[i];
                    var fullName = $"{name} {lastName}";
                    var rank     = ranks.TryGetValue(name, out var r) ? r : 999;
                    var (popLabel, popClass) = GetPopularity(rank);
                    var meaning  = meanings.TryGetValue(name, out var m) ? m : "";

                    <div class="name-card @(i == 0 ? "name-card-top" : "")"
                         data-name="@name"
                         style="z-index: @(10 - i); cursor: @(i == 0 ? "grab" : "default");">
                        <div class="card-overlay"></div>
                        <div class="name-card-inner">
                            <div class="name-card-emoji">@GetEmoji(name)</div>
                            <h2 class="name-card-fullname">@fullName</h2>
                            <p class="name-card-firstname text-muted">@name</p>
                            @if (!string.IsNullOrEmpty(meaning))
                            {
                                <p class="name-card-meaning">@meaning</p>
                            }
                            <span class="popularity-badge @popClass">@popLabel</span>
                        </div>
                        <div class="like-indicator">❤️ LIKE</div>
                        <div class="pass-indicator">✕ NOPE</div>
                    </div>
                }
            }
        </div>

        @if (remaining > 0)
        {
            <div class="action-buttons d-flex justify-content-center gap-4 mt-4" id="actionButtons">
                <button class="action-btn action-btn-pass" id="btnPass" title="Pass (←)">
                    <i class="bi bi-x-lg"></i>
                </button>
                <button class="action-btn action-btn-like" id="btnLike" title="Like (→)">
                    <i class="bi bi-heart-fill"></i>
                </button>
            </div>
            <p class="text-center text-muted small mt-2" id="swipeHint">
                ← pass &nbsp;|&nbsp; like →
            </p>
        }

        @* Undo row — always in DOM; JS shows/hides it after each swipe *@
        <div id="undoRow" class="text-center mt-1 d-none">
            <button id="btnUndo" class="btn-undo" title="Undo last swipe (Z)">
                <i class="bi bi-arrow-counterclockwise"></i> Undo
            </button>
        </div>
    </div>
</div>

<!-- Data for JS -->
<input type="hidden" id="remainingNames" value="@System.Text.Json.JsonSerializer.Serialize(Model)" />
<input type="hidden" id="lastName"       value="@lastName" />
<input type="hidden" id="nameRanks"      value="@ViewBag.RanksJson" />
<input type="hidden" id="nameMeanings"   value="@ViewBag.MeaningsJson" />
<input type="hidden" id="totalCount"     value="@totalCount" />
<input type="hidden" id="votedCount"     value="@votedCount" />
@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/swipe.js" asp-append-version="true"></script>
}

@functions {
    static string GetEmoji(string name)
    {
        var emojis = new[] { "🌸", "⭐", "🌟", "✨", "🌿", "🦋", "🌈", "🍀", "🌙", "💫", "🌺", "🎀", "🦄", "🌻", "🍁" };
        return emojis[Math.Abs(name.GetHashCode()) % emojis.Length];
    }

    static (string label, string cssClass) GetPopularity(int rank) => rank switch
    {
        <= 10  => ("🔥 Top 10",      "pop-hot"),
        <= 25  => ("⭐ Top 25",      "pop-top"),
        <= 75  => ("💜 Popular",     "pop-popular"),
        <= 150 => ("🌿 Less Common", "pop-less"),
        _      => ("✨ Rare",        "pop-rare")
    };
}
