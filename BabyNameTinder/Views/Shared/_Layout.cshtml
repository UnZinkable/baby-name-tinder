<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Baby Name Tinder</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top app-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                💕 Baby Name Tinder
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Swipe" asp-action="Index">
                                <i class="bi bi-hand-index-thumb"></i> Swipe
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Match" asp-action="Index">
                                <i class="bi bi-heart-fill text-warning"></i> Matches
                                <span id="matchBadge" class="badge bg-warning text-dark ms-1 d-none">0</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Partner" asp-action="Dashboard">
                                <i class="bi bi-people-fill"></i> Partner
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <span class="text-white me-3 small">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">Sign Up Free</a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <!-- Toast container for match notifications -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;" id="toastContainer"></div>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
        <script>
            const userId = "@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";
            let newMatchCount = 0;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/nameHub")
                .withAutomaticReconnect()
                .build();

            connection.on("Match", function (fullName) {
                showMatchToast(fullName);
                newMatchCount++;
                const badge = document.getElementById("matchBadge");
                if (badge) {
                    badge.textContent = newMatchCount;
                    badge.classList.remove("d-none");
                }
                document.dispatchEvent(new CustomEvent("nameMatch", { detail: fullName }));
            });

            connection.start()
                .then(() => connection.invoke("JoinUserGroup", userId))
                .catch(err => console.error("SignalR:", err));

            function showMatchToast(name) {
                const id = "toast_" + Date.now();
                const html = `
                    <div id="${id}" class="toast match-toast text-white border-0" role="alert">
                        <div class="d-flex">
                            <div class="toast-body">
                                <div class="fw-bold mb-1">💕 It's a match!</div>
                                You both love <strong>${name}</strong> ❤️
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>`;
                document.getElementById("toastContainer").insertAdjacentHTML("beforeend", html);
                const el = document.getElementById(id);
                const toast = new bootstrap.Toast(el, { delay: 6000 });
                toast.show();
                el.addEventListener("hidden.bs.toast", () => el.remove());
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
