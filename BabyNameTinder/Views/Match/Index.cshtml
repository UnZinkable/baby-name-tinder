@model List<string>
@{
    ViewData["Title"] = "Your Matches";
    var lastName = ViewBag.LastName as string ?? "";
    var partner = ViewBag.Partner as string;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">💕 Your Matches</h1>
        @if (partner != null)
        {
            <p class="text-muted">Names you and <strong>@partner</strong> both love</p>
        }
        else
        {
            <p class="text-muted">Names you both love — waiting for your partner to join</p>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">💭</div>
            <h4 class="fw-bold mt-3">No matches yet</h4>
            <p class="text-muted">Keep swiping! When you both like the same name, it'll appear here.</p>
            <a asp-controller="Swipe" asp-action="Index" class="btn btn-primary mt-2">
                Go Swipe →
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
            @foreach (var name in Model)
            {
                <div class="col">
                    <div class="match-card text-center p-3 rounded-4 shadow-sm h-100">
                        <div class="match-emoji mb-2">❤️</div>
                        <div class="fw-bold fs-5">@name</div>
                        <div class="text-muted small">@name @lastName</div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Swipe" asp-action="Index" class="btn btn-outline-primary">
                Keep Swiping →
            </a>
        </div>
    }
</div>
